# Intel HEX Viewer - Git Attributes
# This file defines attributes for paths in the repository

# ===== Auto-detect text files and perform LF normalization =====
* text=auto

# ===== Explicitly declare text files with LF line endings =====
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.dockerfile text eol=lf
Dockerfile text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
Makefile text eol=lf
*.make text eol=lf
*.mk text eol=lf

# ===== Windows-specific files with CRLF =====
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ===== Intel HEX and related files =====
*.hex text eol=lf
*.ihx text eol=lf
*.map text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.c text eol=lf
*.cpp text eol=lf

# ===== Binary files =====
*.bin binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.app binary
*.dmg binary
*.pkg binary
*.deb binary
*.rpm binary
*.tar binary
*.tar.gz binary
*.tar.bz2 binary
*.tar.xz binary
*.zip binary
*.7z binary
*.rar binary
*.gz binary
*.bz2 binary
*.xz binary
*.lz binary
*.lzma binary
*.Z binary

# ===== Images =====
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.svg text eol=lf
*.webp binary
*.tiff binary
*.tif binary

# ===== Audio/Video =====
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.wmv binary
*.flv binary
*.webm binary
*.ogg binary
*.wav binary
*.flac binary

# ===== Documents =====
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.odt binary
*.ods binary
*.odp binary

# ===== Fonts =====
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# ===== Archives and packages =====
*.egg binary
*.whl binary
*.gem binary
*.jar binary
*.war binary
*.ear binary

# ===== Git LFS tracking (if needed in future) =====
# Uncomment if using Git LFS for large files
# *.bin filter=lfs diff=lfs merge=lfs -text
# *.exe filter=lfs diff=lfs merge=lfs -text
# *.so filter=lfs diff=lfs merge=lfs -text
# *.dylib filter=lfs diff=lfs merge=lfs -text
# *.dll filter=lfs diff=lfs merge=lfs -text

# ===== Language-specific attributes =====
*.py linguist-language=Python
*.md linguist-language=Markdown
*.yml linguist-language=YAML
*.yaml linguist-language=YAML
*.json linguist-language=JSON
*.toml linguist-language=TOML
*.sh linguist-language=Shell
*.bat linguist-language=Batchfile
*.ps1 linguist-language=PowerShell

# ===== Project-specific attributes =====
# Mark example files as documentation
examples/* linguist-documentation=true
docs/* linguist-documentation=true
*.md linguist-documentation=true

# Mark test files appropriately
tests/* linguist-generated=false
test_* linguist-generated=false

# Mark build scripts as important
build_* linguist-generated=false
build/* linguist-generated=false

# Mark configuration files as important
*.toml linguist-generated=false
*.cfg linguist-generated=false
*.ini linguist-generated=false
requirements*.txt linguist-generated=false
setup.py linguist-generated=false

# ===== Diff settings =====
*.py diff=python
*.md diff
*.json diff
*.yml diff
*.yaml diff
*.toml diff
*.cfg diff
*.ini diff

# ===== Merge settings =====
*.py merge=text
*.md merge=text
*.json merge=text
*.yml merge=text
*.yaml merge=text
*.toml merge=text

# ===== Export-ignore (files not included in git archive) =====
.gitignore export-ignore
.gitattributes export-ignore
.github/ export-ignore
tests/ export-ignore
docs/ export-ignore
*.md export-ignore
build_* export-ignore
*.yml export-ignore
*.yaml export-ignore
tox.ini export-ignore
.flake8 export-ignore
.pre-commit-config.yaml export-ignore

# ===== End of .gitattributes ===== 