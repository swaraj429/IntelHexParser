# Intel HEX Viewer - Git Ignore File
# This file specifies intentionally untracked files that Git should ignore

# ===== Python =====
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# celery beat schedule file
celerybeat-schedule

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# ===== IDEs and Editors =====
# Visual Studio Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Nano
*.save
*.swp

# ===== Operating Systems =====
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===== Project Specific =====
# Build artifacts
build/
dist/
*.spec

# PyInstaller build files
*.manifest
*.spec

# Test files (except examples)
test_*.hex
sample_*.hex
temp_*.hex
*.tmp

# Log files
*.log
logs/

# Database files
*.db
*.sqlite
*.sqlite3

# Configuration files with sensitive data
config.ini
settings.ini
local_config.py

# Backup files
*.bak
*.backup
*.old

# ===== Documentation =====
# Sphinx build
docs/_build/
docs/build/

# Generated documentation
_build/
_static/
_templates/

# ===== Development Tools =====
# Coverage reports
.coverage
htmlcov/
coverage.xml
*.cover

# Profiling
*.prof

# Benchmarking
benchmark_results/

# ===== Deployment =====
# Docker
Dockerfile.local
docker-compose.override.yml

# Kubernetes
k8s-local/

# ===== Security =====
# API keys and secrets
.env
.env.local
.env.*.local
secrets.py
api_keys.py

# SSL certificates
*.pem
*.key
*.crt

# ===== Temporary Files =====
# Temporary directories
tmp/
temp/
.tmp/

# Lock files
*.lock
.lock

# ===== Custom Exclusions =====
# User-specific hex files (keep examples/)
*.hex
!examples/*.hex
!examples/**/*.hex

# User-specific map files
*.map
!examples/*.map
!examples/**/*.map

# Generated binaries
*.bin
!examples/*.bin
!examples/**/*.bin

# Research and development files
research/
dev_notes/
scratch/

# Personal configuration
.personal/
my_*

# ===== Archives =====
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.7z
*.rar

# ===== Node.js (if adding web components later) =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== End of .gitignore =====
